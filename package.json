{
  "name": "hls-streaming-layer",
  "version": "0.1.0",
  "description": "Stream HLS video as a layer on Mapbox GL maps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "hls.js": "^1.4.0",
    "mapbox-gl": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.1",
    "hls.js": "^1.5.0",
    "mapbox-gl": "^3.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-map-gl": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "@types/react": "^18.0.0"
  },
  "keywords": [
    "mapbox",
    "hls",
    "video",
    "streaming",
    "map",
    "layer",
    "satellite",
    "overlay"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dzole0311/hls-streaming-layer"
  }
}
